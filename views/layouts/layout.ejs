<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Maquinados industriales, grabado de precisión y duplicado de piezas." />
    <meta name="author" content="Carlos Junco">

    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Maquinados Industriales Del Sur">
    <meta property="og:title" content="Maquinados Industriales Del Sur | Precisión Industrial CNC y Láser">
    <meta property="og:description"
        content="Especialistas en maquinados industriales de alta precisión. CNC, corte y grabado láser, fresado, rectificado y soluciones personalizadas para la industria. Calidad, exactitud y profesionalismo.">
    <meta property="og:url" content="https://www.facebook.com/people/Maquinados-Industriales/61588075344418/">
    <meta property="og:image" content="images/og-mainds.png">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:type" content="image/png">
    <meta property="og:locale" content="es_MX">

    <title>
        <%= title %>
    </title>

    <link rel="icon" href="images/gear logo2.png" type="image/png">
    <link rel="stylesheet" href="/css/styles.css" />
    <script defer src="/js/main.js"></script>
    <script type="module" src="/js/model-viewer.min.js"></script>    
</head>

<body>
    <header class="site-header">
        <a href="/" class="brand"><img src="/images/mainds-header1.png" alt="Mainds logo image" class="logo-image"></a>
        <button class="hamburger" id="hamburgerBtn" aria-expanded="false" aria-controls="mainNav">☰</button>
        <nav id="mainNav" class="main-nav">
            <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">Inicio</a>
            <a href="/servicios" class="<%= currentPath === '/servicios' ? 'active' : '' %>">Servicios</a>
            <a href="/contacto" class="<%= currentPath === '/contacto' ? 'active' : '' %>">Contacto</a>
            <a href="/admin" class="<%= currentPath === '/admin' ? 'active' : '' %>">Admin</a>
        </nav>
    </header>

    <% if (notice && notice.length) { %>
        <div class="flash flash-success">
            <%= notice[0] %>
        </div>
        <% } %>
            <% if (error && error.length) { %>
                <div class="flash flash-error">
                    <%= error[0] %>
                </div>
                <% } %>
                    <main>
                        <%- body %>
                    </main>
                    <footer class="site-footer">
                        <p>© <%= year %> Mainds Maquinados Industriales Del Sur.</p>
                        <div class="social-links">
                            <a href="https://www.facebook.com/share/1EZFbMNTCo/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer">Facebook</a>
                        </div>
                    </footer>
</body>

</html>